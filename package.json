{
  "name": "daramadname",
  "description": "درآمدنامه — دفتر دریافتی‌ها و گزارش درآمد قابل ارائه برای فریلنسرها",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run i18n:compile",
    "dev": "vite",
    "prestart": "npm run i18n:compile",
    "start": "vite",
    "prebuild": "npm run i18n:compile",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:tsc": "tsc -b --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,cjs,ts,tsx,json,css,md}\"",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "pwa:icons": "node src/pwa/icons/generate-icons.mjs",
    "prestorybook": "npm run i18n:compile",
    "storybook": "node scripts/storybook-dev.mjs",
    "prebuild-storybook": "npm run i18n:compile",
    "build-storybook": "storybook build",
    "pretest": "npm run i18n:compile",
    "test": "node scripts/vitest.mjs run",
    "test:watch": "node scripts/vitest.mjs",
    "test:unit": "node scripts/vitest.mjs run --project unit",
    "test:storybook": "node scripts/vitest.mjs run --project storybook",
    "test:coverage": "node scripts/vitest.mjs run --coverage"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/stylis-plugin-rtl": "^9.1.1",
    "@mui/system": "^9.2.0",
    "@mui/x-charts": "^9.9.0",
    "@mui/x-date-pickers": "^9.9.0",
    "@tanstack/react-query": "^5.101.2",
    "bidi-js": "^1.0.3",
    "date-fns": "^4.4.0",
    "date-fns-jalali": "^4.4.0-0",
    "dexie": "^4.4.4",
    "fontkit": "^2.0.4",
    "pdfkit": "^0.19.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-router-dom": "^7.18.1",
    "stylis": "4.2.0",
    "vazirmatn": "^33.0.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.5.0",
    "@lingui/swc-plugin": "^6.5.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lingui": "^0.14.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sharp": "^0.35.3",
    "storybook": "^10.5.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "stylis": "4.2.0",
    "@mui/x-date-pickers": {
      "date-fns-jalali": "$date-fns-jalali"
    }
  },
  "allowScripts": {
    "@swc/core@1.15.43": true,
    "esbuild@0.28.1": true
  }
}
