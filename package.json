{
  "name": "daramadname",
  "description": "درآمدنامه — دفتر دریافتی‌ها و گزارش درآمد قابل ارائه برای فریلنسر ایرانی",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "yarn i18n:compile",
    "dev": "vite",
    "prestart": "yarn i18n:compile",
    "start": "vite",
    "prebuild": "yarn i18n:compile",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:tsc": "tsc -b --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,cjs,ts,tsx,json,css,md}\"",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "prestorybook": "yarn i18n:compile",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "yarn i18n:compile",
    "build-storybook": "storybook build",
    "pretest": "yarn i18n:compile",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/vazirmatn": "^5.3.0",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/stylis-plugin-rtl": "^9.1.1",
    "@mui/system": "^9.2.0",
    "@mui/x-charts": "^9.10.0",
    "@mui/x-date-pickers": "^9.10.0",
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.4.0",
    "date-fns-jalali": "^4.4.0-0",
    "dexie": "^4.4.4",
    "pdfmake": "^0.3.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-router-dom": "^7.18.0",
    "stylis": "^4.4.0",
    "vazirmatn": "^33.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.5.0",
    "@lingui/swc-plugin": "^6.5.0",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "^22.10.0",
    "@types/pdfmake": "^0.2.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.2",
    "fake-indexeddb": "^6.0.0",
    "globals": "^17.7.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "storybook": "^10.5.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
